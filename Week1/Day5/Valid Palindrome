class Solution {
    public boolean isPalindrome(String s) {
        String ans = "";

        for(int i = 0 ; i<s.length() ; i++){
            char ch = s.charAt(i);
            if(ch>='A' && ch<='Z'){
                
                ans = ans + (char)(ch+32);
            }
            else if(ch>='a' && ch<='z'){
                ans = ans + ch;
            }
            
        }

        int i = 0;
        int j = ans.length()-1;

        while(i<j){
            if(ans.charAt(i)!=ans.charAt(j)) return false;
            i++;
            j--;
        }
        return true;
    }
}
