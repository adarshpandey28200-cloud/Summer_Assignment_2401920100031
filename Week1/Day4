// matrix diagonal sum
class Solution {
    public int diagonalSum(int[][] arr) {
        int sum = 0;
        int i = 0;
        int j = 0;
        int n = arr.length;
      while(i<n){
        sum = sum + arr[i][j];
        i++;
        j++;
      }
      i = 0;
      j = n-1;

      while(i<n){
        sum = sum + arr[i][j];
        i++;
        j--;
      }
      if(n%2==0) return sum;
      else{
        sum = sum-arr[n/2][n/2];
        return sum;
      }
    }
}
